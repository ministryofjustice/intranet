// include the toolkit (a suite of variables, classes and mixins)
@require "../../globals/css/_toolkit"

.c-inline-featured-image {
  img {
    width: 100%;
    max-width: 100%;
    heigh: auto;
  }

  &__row {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;

    @media only screen and (min-width: 740px) {
      align-items: center;
      flex-wrap: nowrap;
    }
  }

  &__column--text {
    @media only screen and (min-width: 740px) {
      width: 75%;
      flex-shrink: 1;
    }
  }

  &__column--image {
    width: 285px;
    max-width: 100%;
    flex-shrink: 0;
  }
}
