// include the toolkit (a suite of variables, classes and mixins)
@require "../../globals/css/_toolkit"

.c-inline-featured-image {

  margin-bottom: 6rem;
  +above(m) {
    margin-bottom: 10rem;
  }

  img {
    width: 100%;
    max-width: 100%;
    heigh: auto;
  }

  &__row {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;

    +above(m) {
      align-items: center;
      flex-wrap: nowrap;
    }
  }

  &__column--text {
    +above(m) {
      width: 75%;
      flex-shrink: 1;
    }
  }

  &__column--image {
    width: 285px;
    max-width: 100%;
    flex-shrink: 0;
  }
}
